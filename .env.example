# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# MongoDB Atlas connection string
DB_CONNECTION_STRING=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/quietspace

# Generate both of these with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET=

# JWT token expiry in hours (default: 8)
JWT_EXPIRES_HOURS=8

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Set to "true" only during local development, never in production
FLASK_DEBUG=false
